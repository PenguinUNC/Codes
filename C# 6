using System;
class Weapon
{
    public string name;
    public int damage;
}
class Program
{
    static void Main()
    {
        Weapon gun = new Weapon();
        gun.name = "Gun";
        gun.damage = 15;
        Weapon sword = new Weapon();
        sword.name = "Golden Sword";
        sword.damage = 50;
        Console.WriteLine(gun.name + ", damage: " + gun.damage);
        Console.Write(sword.name + ", damage: " + sword.damage);
    }
}
